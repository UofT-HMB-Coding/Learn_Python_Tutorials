knitr::opts_chunk$set(echo = TRUE)
# load libraries
library(readr)
library(tidyverse)
STA288dat<-read_csv("STA288_data.csv")
glimpse(STA288dat)
# group programs in Medicine & FAS
STA288dat<-STA288dat %>%
mutate(Faculty=ifelse(program=="Human Biology"|program=="Biology"|program=="Psychology"|program=="Other Life Science", "Arts & Science", ifelse(program=="Other Non-Life Science","Other","Medicine")))
# Medicine: Biomedical Toxicology, Pharmacology, Molecular Genetics, Immunology, Physiology, Biochemistry
#FAS: Biology, Human Biology, Psychology, Other Life Science
#Number of students removed from study population
sum(STA288dat$Faculty=="Other")
sum(STA288dat$Faculty!="Other")
mean(STA288dat$Faculty=="Other")
glimpse(STA288dat)
# Sample 1 - SRS of n=30 from population
n<-30
set.seed(288)
STA288_SRS<-STA288dat %>%
sample_n(n)
# Sample 2 - Stratified (by Faculty) sample: 2 SRSs of nM=15 & nAS=15
nM<-15
nAS<-15
set.seed(0101)
Medicine_SRS<-STA288dat %>%
filter(Faculty=="Medicine") %>%
sample_n(nM) # take SRS of STA288 students in Medicine program
set.seed(5101)
FAS_SRS<-STA288dat %>%
filter(Faculty=="Arts & Science") %>%
sample_n(nAS) # take SRS of STA288 students in A&S program
STA288_Strat<-bind_rows(Medicine_SRS,FAS_SRS)
write_csv(STA288_SRS, "STA288_SRS.csv")
write_csv(STA288_Strat, "STA288_Strat.csv")
glimpse(STA288_SRS)
glimpse(STA288_Strat)
STA288_SRS %>%
group_by(Faculty) %>%
summarise(n=n(),mean=mean(percent),min=min(percent),median=median(percent),max=max(percent))
STA288_Strat %>%
group_by(Faculty) %>%
summarise(n=n(),mean=mean(percent),min=min(percent),median=median(percent),max=max(percent))
# Data summaries for SRS (n=30)
STA288_SRS %>%
ggplot(aes(x = percent)) +
geom_histogram(binwidth = 8, fill = "grey", color = "black") +
labs(
x = "Percentage",
y = "Frequency",    title = "Life Science research in peer-reviewed journals thought to have statistical errors"
) + theme(axis.title.x=element_text(size=14), axis.title.y=element_text(size=14),plot.title=element_text(size=13.5))
STA288_SRS %>%
summarise(n=n(), phat=mean(percent>50), min=min(percent),
median=median(percent), max=max(percent))
head(STA288_SRS)
glimpse(STA288_SRS)
counts<-STA288_SRS %>%
summarise(n=n(),n_maj=sum(percent>50))
# Z CI for p
prop.test(counts$n_maj,counts$n, correct=FALSE)
# Z CI for p (with continuity correction)
prop.test(counts$n_maj,counts$n)
# Exact Binomial test/CI
binom.test(counts$n_maj,counts$n)
# Bootstrap CI for p
n<-nrow(STA288_SRS) # Sample size
reps<-5000 # Number of bootstrap samples
boot_phats<-vector("numeric",reps)  # initialize vector for bootstrap statistics
set.seed(123)
for(i in 1:reps){
boot_stat<-STA288_SRS %>%
sample_n(size=n,replace=TRUE) %>%
summarise(phat=mean(percent>50))
boot_phats[i]<-boot_stat$phat
}
quantile(boot_phats,c(0.025,0.975))
boot_phats<-tibble(boot_phats=boot_phats) # convert to data frame for 'ggplot'
# save appropriate quantiles in 'limits'; middle 95% between 2.5th and 97.5th quantiles
limits<-quantile(boot_phats$boot_phats,c(0.025,0.975))
boot_phats %>% ggplot(aes(x=boot_phats)) +
geom_histogram(binwidth=0.1, colour="black",fill="grey") +
labs(x="Bootstrap proportions perceiving > 50% LS research to have statistical errors (n=30)") +
# add line at lower limit:
geom_vline(xintercept=limits[1], colour="orange",linetype="dotdash", linewidth=0.8) +
# add line at upper limit:
geom_vline(xintercept=limits[2], colour="orange",linetype="dotdash", linewidth=0.8) +
theme(axis.title.x=element_text(size=9),
axis.title.y=element_text(size=13))
limits # show the quantiles
# show Z CI calculations
qnorm(0.025)
qnorm(0.975)
0.3333-1.96*sqrt(0.3333*0.6667/30)
0.3333+1.96*sqrt(0.3333*0.6667/30)
# Data summaries for stratified sample (2 SRSs)
STA288_Strat %>%
filter(Faculty!="Other") %>%
ggplot(aes(
x = Faculty,    # x = categorical/qualitative variable
y = percent   # y = numerical/quantitative variable
)) +
geom_boxplot() +
labs(
x = "Faculty",
y = "Percentage",
title = "Life Science research in peer-reviewed journals thought to have statistical errors"
) +
geom_point(col="grey",alpha=1/2) + theme(axis.title.x=element_text(size=13),
axis.title.y=element_text(size=13),plot.title=element_text(size=13))
STA288_Strat %>%
filter(Faculty!="Other") %>%
group_by(Faculty) %>%
summarise(N=n(), p=mean(mean(percent>50)), min=min(percent),
mu=mean(percent), median=median(percent), max=max(percent))
group_counts<-STA288_Strat %>%
group_by(Faculty) %>%
summarise(n=n(), n_maj=sum(percent>50))
# Z test
prop.test(group_counts$n_maj,group_counts$n,correct=FALSE)
prop.test(group_counts$n_maj,group_counts$n)
# Chi-squared
chisq.test(STA288_Strat$Faculty,STA288_Strat$percent>50)
# Fisher's Exact test
fisher.test(STA288_Strat$Faculty,STA288_Strat$percent>50)
# Z CI limits
(8/15-5/15)-qnorm(0.975)*sqrt((8/15)*(1-8/15)/15+(5/15)*(1-5/15)/15)
(8/15-5/15)+qnorm(0.975)*sqrt((8/15)*(1-8/15)/15+(5/15)*(1-5/15)/15)
# Compute sample proportions
phats<-STA288_Strat %>%
group_by(Faculty) %>%
summarise(n=n(), phat=mean(percent>50))
phats
# Compute test statistic (difference in phats (M-AS))
test_stat<-phats$phat[phats$Faculty=="Arts & Science"]-
phats$phat[phats$Faculty=="Medicine"]
# setting up simulation
reps<-5000 # Number of shuffles
sim_diff<-vector("numeric",reps)  # initialize vector for simulated phat differences
for (i in 1:reps) {
sim<-STA288_Strat %>%
mutate(Faculty=sample(Faculty)) # this shuffles Faculty across students
# determine sample proportions for simulated data
sim_phats<-sim %>%
group_by(Faculty) %>%
summarise(n=n(), phat=mean(percent>50))
# compute difference in sample proportions
sim_diff[i]<-sim_phats$phat[sim_phats$Faculty=="Arts & Science"]-
sim_phats$phat[sim_phats$Faculty=="Medicine"]
}
diff_phats<-tibble(diff=sim_diff) # convert to tibble to use ggplot functions
# find estimated p-value using diff_phats (two-sided test so need proportion
# of simulated differences in phats in the tails)
diff_phats %>%
summarise(n=n(), p_value=mean(diff<=-abs(test_stat)|diff>=abs(test_stat)))
test_stat
diff_phats %>% ggplot(aes(x=diff)) +
geom_histogram(binwidth=0.05,colour="black", fill="grey") +
labs(x="Difference in Sample Proportions(FAS-Medicine)", y="Frequency") +
geom_vline(xintercept=-abs(test_stat), colour="blue",linetype = 2,linewidth=0.8) +
geom_vline(xintercept=abs(test_stat), colour="blue",linetype = 2,linewidth=0.8)
